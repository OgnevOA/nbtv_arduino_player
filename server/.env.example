# Copy to .env and fill in. Do NOT commit the real .env.
# Telegram bot token from @BotFather:
BOT_TOKEN=123456789:AA...replace...

# Your numeric Telegram user id (from @userinfobot). Only this user is allowed:
ALLOWED_USER_ID=000000000

# Shared secret the ESP32 sends as X-Device-Token. Must match firmware secrets.h
# (NBTV_DEVICE_TOKEN). Any random string; leave blank to disable auth on LAN.
DEVICE_TOKEN=change-me-to-a-random-string
